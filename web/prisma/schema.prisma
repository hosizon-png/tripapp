generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String         @id @default(uuid())
  phone         String?        @unique
  phoneVerified Boolean        @default(false)
  email         String?        @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  avatarUrl     String?
  wechatOpenId  String?        @unique
  wechatUnionId String?
  appleId       String?        @unique
  subscription  Subscription?
  smsCodes      SmsCode[]
  refreshTokens RefreshToken[]
  trips         Trip[]
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  device    String?
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model SmsCode {
  id        String   @id @default(uuid())
  phone     String
  code      String
  type      String
  used      Boolean  @default(false)
  expiresAt DateTime
  ip        String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  access_token      String?
  refresh_token     String?
  expires_at        Int?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
  sessionToken String   @unique
}

model Subscription {
  id        String    @id @default(uuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier      String    @default("free")
  startDate DateTime  @default(now())
  endDate   DateTime?
  autoRenew Boolean   @default(false)
  orderId   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model PaymentOrder {
  id        String    @id @default(uuid())
  userId    String
  tier      String
  period    String
  amount    Float
  status    String    @default("pending")
  provider  String
  tradeNo   String?
  paidAt    DateTime?
  createdAt DateTime  @default(now())
}

model Trip {
  id          String          @id @default(uuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  destination String?
  coverImage  String?
  startDate   DateTime?
  endDate     DateTime?
  lat         Float?
  lng         Float?
  cityId      String?
  shareToken  String?         @unique
  isPublic    Boolean         @default(false)
  templateId  String?
  items       ItineraryItem[]
  documents   Document[]
  checklists  Checklist[]
  expenses    Expense[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model TripTemplate {
  id          String   @id @default(uuid())
  title       String
  description String?
  destination String
  coverImage  String
  days        Int
  tags        String   @default("[]")
  items       String   @default("[]")
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model ItineraryItem {
  id           String     @id @default(uuid())
  tripId       String
  trip         Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  dayNumber    Int
  type         String
  title        String
  description  String?
  startTime    String?
  endTime      String?
  locationName String?
  address      String?
  lat          Float?
  lng          Float?
  bookingRef   String?
  notes        String?
  orderIndex   Int        @default(0)
  documents    Document[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Document {
  id              String         @id @default(uuid())
  tripId          String
  trip            Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  itineraryItemId String?
  itineraryItem   ItineraryItem? @relation(fields: [itineraryItemId], references: [id])
  name            String
  fileUrl         String
  fileType        String
  fileSize        Int
  category        String
  createdAt       DateTime       @default(now())
}

model Checklist {
  id        String          @id @default(uuid())
  tripId    String
  trip      Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  title     String
  items     ChecklistItem[]
  createdAt DateTime        @default(now())
}

model ChecklistItem {
  id          String    @id @default(uuid())
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  content     String
  isCompleted Boolean   @default(false)
  orderIndex  Int       @default(0)
}

model Expense {
  id          String   @id @default(uuid())
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  category    String
  amount      Float
  currency    String   @default("CNY")
  description String?
  date        DateTime?
  createdAt   DateTime @default(now())
}

model WeatherCache {
  id        String   @id @default(uuid())
  cityId    String
  date      DateTime
  data      String
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([cityId, date])
}

model ExchangeRate {
  id        String   @id @default(uuid())
  from      String
  to        String
  rate      Float
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([from, to])
}
